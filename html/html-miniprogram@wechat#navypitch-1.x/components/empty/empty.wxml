<!--
  df-empty · 空状态组件
  用法一（属性驱动）: <df-empty icon="📅" title="暂无" description="提示" actionText="新建" bind:action="..." />
  用法二（插槽扩展）: <df-empty icon="📅" title="暂无"><view slot="extra">自定义区域</view></df-empty>
  用法三（完全自定义）: <df-empty icon=""><view>…</view></df-empty>
-->
<view class="empty-root">
  <!-- 图标 -->
  <view class="empty-icon" wx:if="{{ icon }}">
    <text>{{ icon }}</text>
  </view>

  <!-- 标题 -->
  <view class="empty-title" wx:if="{{ title }}">
    <text>{{ title }}</text>
  </view>

  <!-- 描述 -->
  <view class="empty-desc" wx:if="{{ description }}">
    <text>{{ description }}</text>
  </view>

  <!-- 操作按钮 -->
  <view
    wx:if="{{ actionText }}"
    class="empty-action empty-action-{{ actionColor }}"
    bindtap="handleAction"
  >
    <text>{{ actionText }}</text>
  </view>

  <!-- 扩展插槽（按钮下方附加内容） -->
  <slot name="extra" />
</view>
