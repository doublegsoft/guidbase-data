/* ═══════════════════════════════════════════
   Calendar · navypitch Design System
   ═══════════════════════════════════════════ */
.cal {
  display: flex;
  flex-direction: column;
  background: var(--color-card);
}

/* ── 头部 · Navy ── */
.cal-hd {
  background: var(--color-navy);
  padding: var(--space-6) var(--space-5) var(--space-5);
}

.cal-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ── 月/周切换 · Tabs pattern ── */
.cal-tabs {
  display: flex;
  background: rgba(255,255,255,0.10);
  border-radius: var(--radius-pill);
  padding: 4rpx;
  flex-shrink: 0;
}

.cal-tab {
  width: 80rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: rgba(255,255,255,0.60);
  border-radius: var(--radius-pill);
  transition: all var(--transition-base);
}

.cal-tab-on {
  background: var(--color-teal);
  color: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0,201,167,0.35);
}

/* ── 标题 ── */
.cal-mid {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.cal-ttl {
  font-size: var(--text-body);
  font-weight: var(--weight-bold);
  color: #fff;
  letter-spacing: 1rpx;
}

.cal-sub {
  font-size: var(--text-xs);
  color: rgba(255,255,255,0.65);
  margin-top: 2rpx;
}

/* ── 导航箭头 ── */
.cal-arrows {
  display: flex;
  gap: var(--space-3);
  flex-shrink: 0;
}

.cal-arr {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: rgba(255,255,255,0.10);
  transition: background var(--transition-base);
}
.cal-arr:active { background: rgba(255,255,255,0.22); }

.cal-arr text {
  color: #fff;
  font-size: var(--text-3xl);
  font-weight: var(--weight-light);
  line-height: 1;
  margin-top: -3rpx;
}

/* ── 星期表头 ── */
.cal-wdr {
  display: flex;
  background: var(--color-surface);
}

.cal-wdc {
  flex: 1;
  text-align: center;
  padding: var(--space-5) 0;
  font-size: var(--text-xs);
  font-weight: var(--weight-semibold);
  color: var(--color-text-muted);
}

.cal-wdc-we { color: var(--color-red-text); }

/* ── 月视图网格 ── */
.cal-mg {
  display: flex;
  flex-wrap: wrap;
}

.cal-mc {
  width: calc(100% / 7);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-4) 0 var(--space-4);
  box-sizing: border-box;
  transition: background var(--transition-fast);
}
.cal-mc:active { background: var(--color-surface); }

.cal-mc-o .cal-mn { color: var(--color-text-muted); }
.cal-mc-s { background: var(--color-teal-dim); }

.cal-mn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-md);
  font-weight: var(--weight-medium);
  color: var(--color-text-main);
  border-radius: var(--radius-full);
}

.cal-mn-t {
  background: var(--color-teal);
  color: #fff;
  font-weight: var(--weight-bold);
}

/* 月视图 事件圆点 */
.cal-mdots {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4rpx;
  margin-top: var(--space-2);
  padding: 0 4rpx;
}

/* ── 周视图 · week-strip ── */
.cal-week {
  background: var(--color-card);
}

.cal-ws {
  display: flex;
  padding: var(--space-4) var(--space-3);
}

.cal-wd {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-4) var(--space-1) var(--space-5);
  border-radius: var(--radius-md);
  transition: background var(--transition-fast);
}
.cal-wd:active { background: var(--color-surface); }

.cal-wd-s { background: var(--color-teal-dim); }

.cal-wd-lbl {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  font-weight: var(--weight-medium);
}

.cal-wd-we .cal-wd-lbl { color: var(--color-red-text); }

.cal-wd-num {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-2xl);
  font-weight: var(--weight-bold);
  color: var(--color-text-main);
  border-radius: var(--radius-full);
  margin-top: var(--space-2);
}

.cal-wd-num-t {
  background: var(--color-teal);
  color: #fff;
}

.cal-wd-num-s {
  color: var(--color-teal-text);
  font-weight: var(--weight-extrabold);
}

/* 周视图 事件圆点 */
.cal-wd-dots {
  display: flex;
  gap: 4rpx;
  margin-top: var(--space-3);
}

.cal-wd-spacer {
  height: 14rpx;
  margin-top: var(--space-3);
}

/* ── 通用圆点 ── */
.cal-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.cal-dm {
  font-size: var(--text-2xs);
  color: var(--color-text-muted);
  line-height: 1;
}
